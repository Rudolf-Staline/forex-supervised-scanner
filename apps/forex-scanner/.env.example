# Forex scanner safety environment variables.
# Required before launching the app or any script that can create execution intents.
EXECUTION_MODE=paper
ALLOW_LIVE_TRADING=false
BROKER_MODE=paper
AUTO_BOT_ENABLED=false
MT5_DEMO_ONLY=true
AUTO_BOT_INTERVAL_SECONDS=300
AUTO_BOT_MIN_SCORE=75
AUTO_BOT_ALLOWED_STATUSES=approved,premium
AUTO_BOT_MAX_OPEN_TRADES=3
AUTO_BOT_MAX_TRADES_PER_DAY=5
AUTO_BOT_COOLDOWN_MINUTES=30
AUTO_BOT_MIN_RR=1.5
MAX_TRADES_PER_DAY=3
MAX_OPEN_TRADES=2
MAX_DAILY_LOSS_PERCENT=2
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_AFTER_LOSS_MINUTES=60
COOLDOWN_AFTER_TRADE_MINUTES=30
RISK_PER_TRADE_PERCENT=0.25
MAX_VOLUME_PER_TRADE=0.05
POSITION_SIZING_MODE=auto
ALLOW_MULTI_ASSET_DEMO_TRADING=false

# Optional MT5 demo variables for Deriv-Demo.
# Use only with BROKER_MODE=mt5_demo and MT5_DEMO_ONLY=true.
# Never commit real secrets in .env files.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Deriv-Demo
MT5_PATH=

# Legacy optional broker environment variables.
# Keep these empty for the local paper/demo MVP.

# Optional MT5 terminal path. Leave unset to use the default installed terminal.
FOREX_SCANNER_MT5_PATH=

# MT5 credentials for sandbox/live use. Do not commit real secrets.
FOREX_SCANNER_MT5_LOGIN=
FOREX_SCANNER_MT5_PASSWORD=
FOREX_SCANNER_MT5_SERVER=

# Live mode is blocked unless this exact value is present and both
# broker.live_enabled=true and execution_capabilities.broker_live_enabled=true in config.
FOREX_SCANNER_BROKER_LIVE_CONFIRM=

# Emergency disable. Set to true/1/on/yes to block broker live submissions.
FOREX_SCANNER_BROKER_KILL_SWITCH=

# Optional local/operator webhook for alert routing. Disabled in config by default.
FOREX_SCANNER_ALERT_WEBHOOK_URL=
